# ── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=assetmaster
DB_USERNAME=assetmaster
DB_PASSWORD=assetmaster

# ── JWT ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change-me-to-a-very-long-random-hex-string-in-production
JWT_ACCESS_EXPIRY_SEC=900
JWT_REFRESH_EXPIRY_SEC=2592000

# ── MinIO / S3 ────────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=assetmaster
MINIO_ACCESS_KEY=assetmaster
MINIO_SECRET_KEY=assetmaster_secret

# ── Server ────────────────────────────────────────────────────
SERVER_PORT=8080

# ── Email / SMTP ───────────────────────────────────────────────
# Gmail: увімкніть двоетапну верифікацію та створіть App Password
# Google Account → Security → 2-Step Verification → App passwords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# URL фронтенду для генерації посилань у листах
APP_BASE_URL=http://localhost:5173
